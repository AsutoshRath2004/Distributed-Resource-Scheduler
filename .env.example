# MongoDB
MONGO_URI=mongodb://localhost:27017/distributed-scheduler

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Scheduler Service
SCHEDULER_PORT=3001

# Worker Service (each worker instance gets its own port + ID)
WORKER_PORT=3002
WORKER_ID=worker-1

# Heartbeat interval in milliseconds
HEARTBEAT_INTERVAL=5000

# How long (ms) before a silent worker is marked offline
WORKER_TIMEOUT=15000
